<!--pages/record/record.wxml-->
<view class="container p-4 pb-20">
  <view class="flex items-center gap-2 mb-6">
    <view class="text-2xl font-bold text-gray-900 tracking-tight">长篇会议纪要档案库</view>
  </view>

  <view wx:if="{{loading}}" class="text-center text-gray-400 py-10 flex flex-col items-center">
    <view class="mb-2">🌐</view>
    <view>光速穿过海底光缆拉取中...</view>
  </view>
  <view wx:if="{{!loading && records.length === 0}}" class="text-center text-gray-400 py-10 flex flex-col items-center">
    <view class="mb-2 text-2xl">📝</view>
    <view>暂无任何纪要档案，请前往网页后台极速入库。</view>
  </view>

  <view wx:for="{{records}}" wx:key="id" class="card p-5 mb-4 shadow-sm relative overflow-hidden active:bg-gray-50 transition-colors" bindtap="goToDetail" data-id="{{item.id}}">
    <!-- 装饰彩带 -->
    <view class="absolute top-0 left-0 w-1 h-full bg-blue-500"></view>
    
    <view class="text-lg font-bold text-gray-900 mb-3 leading-snug">{{item.title}}</view>
    
    <!-- 纯文本去皮摘要预览 -->
    <view class="text-sm text-gray-600 mb-4 line-clamp-2" style="max-height: 40px; overflow: hidden; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;">
      {{item.html_content}}
    </view>

    <view class="text-xs text-gray-400 flex justify-between items-center border-t border-gray-100 pt-3">
      <view class="flex items-center gap-1">
        <text class="font-medium text-blue-600">全局流水号 #{{item.id}}</text>
      </view>
      <text>{{item.created_at}}</text>
    </view>
  </view>
</view>