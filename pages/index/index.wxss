.logo-box {
  width: 32px;
  height: 32px;
  border-radius: 8px;
}
.avatar {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  background-color: #e5e7eb;
}
.banner-bg {
  background: linear-gradient(to right, #2563eb, #3b82f6);
  position: relative;
  overflow: hidden;
}
.banner-bg::after {
  content: '🏫';
  position: absolute;
  right: -10px;
  bottom: -20px;
  font-size: 100px;
  opacity: 0.1;
}
.signin-btn {
  background-color: #1E88E5;
  color: white;
  padding: 0 24px;
  height: 36px;
  line-height: 36px;
  border-radius: 18px;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.icon-box {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
}
