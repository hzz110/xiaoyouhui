<view class="container p-4 pb-20">
  <!-- Header -->
  <view class="flex items-center justify-between mb-4">
    <view class="flex items-center gap-2">
      <view class="logo-box bg-blue-600 flex items-center justify-center text-white">🏫</view>
      <text class="text-xl font-semibold text-gray-900">西南交大校友会</text>
    </view>
    <view class="flex items-center gap-3">
      <view class="text-2xl" bindtap="showNotification">🛎️</view>
      <image class="avatar" src="https://picsum.photos/id/64/64/64"></image>
    </view>
  </view>

  <!-- Welcome Banner -->
  <view class="card p-5 mb-6 banner-bg">
    <view class="text-2xl font-bold text-white">欢迎回来，李校友！</view>
    <view class="text-blue-100 mt-1 text-sm">今天是校友会成立 15 周年纪念日 🎉</view>
  </view>

  <!-- 即将会议 -->
  <view class="mb-6">
    <view class="flex justify-between items-center mb-3 px-1">
      <text class="font-semibold text-lg">即将会议</text>
      <navigator url="/pages/activity/activity" open-type="redirect" class="text-blue-600 text-sm">全部活动 →</navigator>
    </view>
    <view class="card p-4" bindtap="goToActivity">
      <view wx:if="{{loading}}" class="text-center text-gray-400 py-4">飞向云端拉取最新会议...</view>
      <view wx:if="{{!loading && latestEvent}}" class="flex justify-between items-center">
        <view class="flex-1 pr-2">
          <view class="text-base font-medium truncate" style="max-width: 180px;">{{latestEvent.title}}</view>
          <view class="text-xs text-gray-500 mt-1 truncate">📍 {{latestEvent.location}} · 录入于 {{latestEvent.created_at}}</view>
        </view>
        <navigator url="/pages/signin/signin" class="bg-blue-500 text-white px-4 py-2 rounded-full text-xs font-medium shadow-md">
          去签到
        </navigator>
      </view>
      <view wx:if="{{!loading && !latestEvent}}" class="text-center text-gray-500 py-4">
        暂无最新会议，快去后台发布吧！
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="mb-8">
    <view class="text-lg font-semibold mb-3 px-1">快速入口</view>
    <view class="quick-grid">
      <navigator url="/pages/signin/signin" class="flex flex-col items-center gap-1">
        <view class="bg-blue-100 icon-box">📍</view>
        <text class="text-xs">会议签到</text>
      </navigator>
      <navigator url="/pages/alumni/alumni" class="flex flex-col items-center gap-1">
        <view class="bg-orange-100 icon-box">👥</view>
        <text class="text-xs">校友管理</text>
      </navigator>
      <navigator url="/pages/record/record" class="flex flex-col items-center gap-1">
        <view class="bg-purple-100 icon-box">📝</view>
        <text class="text-xs">会议记录</text>
      </navigator>
      <view bindtap="notAvailable" class="flex flex-col items-center gap-1">
        <view class="bg-green-100 icon-box">📅</view>
        <text class="text-xs">发布活动</text>
      </view>
    </view>
  </view>

  <!-- 最近动态 -->
  <view>
    <view class="font-semibold text-lg px-1 mb-3">最近动态</view>
    <view class="card p-4 flex gap-3 mb-3">
      <view class="text-3xl">📸</view>
      <view class="flex-col">
        <view class="text-sm font-medium">2025秋季校友聚会照片已上传</view>
        <view class="text-xs text-gray-500 mt-1">张伟 · 3小时前</view>
      </view>
    </view>
    <view class="card p-4 flex gap-3">
      <view class="text-3xl">🎤</view>
      <view class="flex-col">
        <view class="text-sm font-medium">王教授分享：AI时代下的校友创业</view>
        <view class="text-xs text-gray-500 mt-1">校友会 · 昨天</view>
      </view>
    </view>
  </view>
</view>

<!-- Custom Bottom Tab Bar Simulation -->
<view class="tab-bar">
  <navigator url="/pages/index/index" open-type="redirect" class="tab-item active">
    <view class="text-2xl">🏠</view>
    <text>首页</text>
  </navigator>
  <navigator url="/pages/activity/activity" open-type="redirect" class="tab-item">
    <view class="text-2xl">📅</view>
    <text>活动</text>
  </navigator>
  <navigator url="/pages/alumni/alumni" open-type="redirect" class="tab-item">
    <view class="text-2xl">👥</view>
    <text>校友</text>
  </navigator>
  <navigator url="/pages/profile/profile" open-type="redirect" class="tab-item">
    <view class="text-2xl">👤</view>
    <text>我的</text>
  </navigator>
</view>
