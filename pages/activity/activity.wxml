<view class="container p-4 pb-20">
  <view class="text-xl font-semibold mb-4">校友活动</view>
  
  <!-- Tabs -->
  <view class="flex bg-gray-100 rounded-3xl p-1 mb-6" style="border-radius: 24px;">
    <view class="flex-1 text-center py-3 font-medium {{currentTab === 'upcoming' ? 'bg-white shadow-sm' : ''}}" style="border-radius:24px;" bindtap="switchTab" data-tab="upcoming">即将举行</view>
    <view class="flex-1 text-center py-3 font-medium {{currentTab === 'past' ? 'bg-white shadow-sm' : ''}}" style="border-radius:24px;" bindtap="switchTab" data-tab="past">历史记录</view>
  </view>

  <!-- 即将举行 -->
  <view wx:if="{{currentTab === 'upcoming'}}">
    <view class="card p-4 mb-4">
      <view class="flex justify-between items-start">
        <view>
          <view class="font-semibold text-base">2026春季校友座谈会</view>
          <view class="text-sm text-gray-500 mt-1">2026.04.15 14:00　学校报告厅</view>
          <view class="mt-3 text-xs flex items-center gap-4">
            <text>👥 已签到 <text class="font-semibold text-green-600">45</text>/120</text>
          </view>
        </view>
        <navigator url="/pages/signin/signin" class="bg-blue-600 text-white px-6 py-2 rounded-full text-sm">立即签到</navigator>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view wx:if="{{currentTab === 'past'}}">
    <navigator url="/pages/record/record" class="card p-4 mb-4">
      <view class="flex justify-between items-start">
        <view>
          <view class="font-semibold text-base">2025秋季校友座谈会</view>
          <view class="text-sm text-gray-500 mt-1">2025.10.20 13:30　圆满结束</view>
          <view class="text-xs text-gray-400 mt-2">120人参会 · 纪要已发布</view>
        </view>
        <view class="text-blue-600 text-sm">查看记录 →</view>
      </view>
    </navigator>
  </view>

</view>

<!-- Bottom Tab Bar -->
<view class="tab-bar">
  <navigator url="/pages/index/index" open-type="redirect" class="tab-item">
    <view class="text-2xl">🏠</view>
    <text>首页</text>
  </navigator>
  <navigator url="/pages/activity/activity" open-type="redirect" class="tab-item active">
    <view class="text-2xl">📅</view>
    <text>活动</text>
  </navigator>
  <navigator url="/pages/alumni/alumni" open-type="redirect" class="tab-item">
    <view class="text-2xl">👥</view>
    <text>校友</text>
  </navigator>
  <navigator url="/pages/profile/profile" open-type="redirect" class="tab-item">
    <view class="text-2xl">👤</view>
    <text>我的</text>
  </navigator>
</view>