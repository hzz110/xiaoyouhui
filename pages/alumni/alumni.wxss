.border-gray {
  border: 1px solid #e5e7eb;
}
.whitespace-nowrap {
  white-space: nowrap;
}
.filter-chip {
  display: inline-block;
  padding: 8px 24px;
  background-color: white;
  border-radius: 24px;
  font-size: 14px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}
.filter-chip.active {
  background-color: #1E88E5;
  color: white;
}
.avatar-md {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background-color: #e5e7eb;
  flex-shrink: 0;
}
.rounded {
  border-radius: 4px;
}
